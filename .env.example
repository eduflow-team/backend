# === Application ===
PROJECT_NAME=eduflow
API_V1_STR=/api/v1

# === Database ===
POSTGRES_USER=eduflow
POSTGRES_PASSWORD=eduflow
POSTGRES_DB=eduflow
DATABASE_URL=postgresql+asyncpg://eduflow:eduflow@localhost:5432/eduflow

# === Authentication (JWT) ===
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# === CORS ===
BACKEND_CORS_ORIGINS=

# === Signup ===
TEACHER_SIGNUP_CODE=

# === OpenAI (Stage1 문서·질의 임베딩 / 채점 피드백) ===
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=768
OPENAI_CHAT_MODEL=gpt-4o-mini
# Stage1 chunk_size 허용값(코드 상수): 50, 200, 500, 1200, 3000

# === Langflow (AI 총괄 연동용 — Stage1 chat / Stage2 생성은 현재 mock) ===
LANGFLOW_URL=http://localhost:7860
LANGFLOW_API_KEY=
LANGFLOW_STAGE1_CHAT_FLOW_ID=
LANGFLOW_STAGE2_FLOW_ID=
